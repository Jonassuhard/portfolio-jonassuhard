{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start -- --hostname 127.0.0.1 --port 3000",
      "startServerReadyPattern": "Ready",
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/recruteurs",
        "http://127.0.0.1:3000/projets",
        "http://127.0.0.1:3000/preuves"
      ],
      "numberOfRuns": 2,
      "settings": {
        "chromeFlags": "--no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.95
          }
        ],
        "categories:seo": [
          "error",
          {
            "minScore": 0.95
          }
        ]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
