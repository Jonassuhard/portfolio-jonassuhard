{
  "name": "portfolio-preuves",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:cv": "python scripts/generate-cv-pdf.py",
    "generate:md": "tsx scripts/generate-project-md.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts",
    "check:content": "tsx scripts/check-content.ts",
    "check:links": "tsx scripts/check-links.ts",
    "check:links:external": "tsx scripts/check-links.ts --external",
    "check": "tsx scripts/generate-project-md.ts && tsc --noEmit && tsx --test tests/*.test.ts && tsx scripts/check-content.ts && tsx scripts/check-links.ts",
    "prebuild": "tsx scripts/generate-project-md.ts",
    "build": "next build",
    "start": "next start"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
